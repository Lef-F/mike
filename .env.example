# Mike — self-hosted docker-compose stack.
# 1. cp .env.example .env
# 2. ./scripts/generate-secrets.sh
# 3. Set ANTHROPIC_API_KEY (or GEMINI_API_KEY / OPENROUTER_API_KEY).
# 4. ./mike up

# =============================================================================
# Deployment modes — pick how the auth/DB and storage layers are provisioned.
# =============================================================================

# Auth + database backplane.
#   bundled-full   — we run Postgres + GoTrue + PostgREST (homelab default).
#   bundled-byo-db — you bring Postgres (Neon, RDS, Supabase DB-only); we run
#                    GoTrue + PostgREST against it. Set EXTERNAL_POSTGRES_URL.
#   external       — Hosted Supabase. Set EXTERNAL_SUPABASE_* below.
MIKE_SUPABASE_MODE=bundled-full

# Object storage backplane.
#   bundled  — Garage container in-cluster (homelab default).
#   external — R2, AWS S3, MinIO elsewhere. Set R2_ENDPOINT_URL + creds below.
MIKE_STORAGE_MODE=bundled

# =============================================================================
# Ingress
# =============================================================================
# Caddy listens on MIKE_PORT on the host. The frontend bakes URLs at build
# time, so changing MIKE_HOST or MIKE_PORT requires:
#   ./mike build mike-frontend
MIKE_HOST=localhost
MIKE_PORT=80

# =============================================================================
# Postgres — used by bundled-full (in-cluster) AND init-db (all modes)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD=                 # set by generate-secrets.sh
AUTHENTICATOR_PASSWORD=            # set by generate-secrets.sh; PostgREST role

# Required when MIKE_SUPABASE_MODE=bundled-byo-db.
# Base connection string for the external Postgres. GoTrue and PostgREST
# may need role-specific or schema-specific variants — see
# EXTERNAL_SUPABASE_GOTRUE_PG_URL (Supabase section) and
# EXTERNAL_POSTGRES_AUTHENTICATOR_URL below.
# Example: postgres://user:pw@db.example.com:5432/mike?sslmode=require
EXTERNAL_POSTGRES_URL=

# Required when MIKE_SUPABASE_MODE=bundled-byo-db: PostgREST connects with
# a dedicated 'authenticator' role (RLS pattern). Use the same external
# Postgres as EXTERNAL_POSTGRES_URL but with user=authenticator and the
# corresponding password.
# Example: postgres://authenticator:pw@db.example.com:5432/mike?sslmode=require
EXTERNAL_POSTGRES_AUTHENTICATOR_URL=

# =============================================================================
# Supabase / GoTrue keys — used by bundled-* modes
# =============================================================================
JWT_SECRET=                        # set by generate-secrets.sh
SUPABASE_PUBLISHABLE_KEY=          # set by generate-secrets.sh (anon JWT)
SUPABASE_SECRET_KEY=               # set by generate-secrets.sh (service_role JWT)

# Required when MIKE_SUPABASE_MODE=external (Hosted Supabase).
# From Supabase Project Settings → API and → Database → Connection string.
EXTERNAL_SUPABASE_URL=             # e.g. https://xyz.supabase.co
EXTERNAL_SUPABASE_ANON_KEY=        # anon (publishable) key from API settings
EXTERNAL_SUPABASE_SERVICE_KEY=     # service_role (secret) key from API settings
EXTERNAL_SUPABASE_PG_URL=          # postgres://… connection string for migrations

# GoTrue's DB connection string. In bundled-byo-db mode you usually want this
# to point at the same external PG as EXTERNAL_POSTGRES_URL but with
# &search_path=auth (or ?search_path=auth) appended so GoTrue's migrations
# land in the auth schema. Leave empty in bundled-full and external modes.
EXTERNAL_SUPABASE_GOTRUE_PG_URL=

# =============================================================================
# Backend secrets (always required)
# =============================================================================
DOWNLOAD_SIGNING_SECRET=           # set by generate-secrets.sh; HMAC for /download/:token
USER_API_KEYS_ENCRYPTION_KEY=      # set by generate-secrets.sh; encrypts user LLM keys at rest

# =============================================================================
# GoTrue tuning — used by bundled-* modes (laptop defaults shown)
# =============================================================================
GOTRUE_MAILER_AUTOCONFIRM=true     # set false + add SMTP for real email
GOTRUE_DISABLE_SIGNUP=false

# =============================================================================
# LLM providers (set at least one for users without their own keys)
# =============================================================================
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# MCP Connectors (optional)
# =============================================================================
# Externally-reachable backend URL used by MCP OAuth 2.1 callbacks.
BACKEND_PUBLIC_URL=http://localhost:80/backend
# Allow MCP server URLs that point at private/loopback IPs (laptop dev).
# In public-facing deployments, leave unset to default-deny.
MCP_ALLOW_PRIVATE_HOSTS=true

# =============================================================================
# Object storage
# =============================================================================
R2_BUCKET_NAME=mike

# Bundled storage (MIKE_STORAGE_MODE=bundled):
#   R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY are auto-generated by the
#   init-garage container on first boot. The backend reads them from
#   /run/secrets/garage.env. Do not set them below for bundled mode.
GARAGE_RPC_SECRET=                 # set by generate-secrets.sh
GARAGE_ADMIN_TOKEN=                # set by generate-secrets.sh

# External storage (MIKE_STORAGE_MODE=external): set the four below.
R2_ENDPOINT_URL=                   # https://<acct>.r2.cloudflarestorage.com, https://s3.<region>.amazonaws.com, etc.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto                     # 'auto' works for R2; set the real region for AWS S3
R2_FORCE_PATH_STYLE=false          # true for MinIO with non-DNS endpoints
